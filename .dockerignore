# Git and IDE
.git
.gitignore
.vs
.vscode
.idea
*.user
*.suo

# SDK version: do not copy so container uses image's SDK (e.g. 9.0.100)
global.json

# Build outputs (rebuilt inside container)
**/bin
**/obj
**/out

# Test projects are included so "dotnet test" can run during Docker build (see Dockerfile).
# The runtime image (final stage) does not contain test code.

# Docker profile and Docker-related files (do not include in image context)
**/Dockerfile*
**/docker-compose*
**/docker-compose.*
**/.dockerignore
**/*.dcproj

# Docs and misc (optional; reduces context size)
**/*.md
!README.md
docs
.attachments

# NuGet local cache (not needed)
**/.nuget
**/packages

# OS and other
**/Thumbs.db
**/.DS_Store
**/agent-transcripts
**/terminals
